# 复制到 .env 并按需填写
# Copy to .env and fill in

# ===== 数据库 / Database =====
# 本地开发用 SQLite（不用改）
# Local dev: SQLite (no change needed)
DATABASE_URL="file:./dev.db"

# 生产用 PostgreSQL（部署 Railway 时这个由 Railway 自动注入）
# Production: PostgreSQL (auto-injected by Railway)
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ===== Cloudinary（图片云存储） =====
# 没填这三个的话上传会自动落到 public/uploads/，方便本地测试
# If unset, uploads fall back to local public/uploads/ (great for local dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== 管理员后台密码 =====
# /admin 入口的密码（Phase 4 后台才会用到，先随便填）
ADMIN_PASSWORD="changeme-in-production"

# ===== Sprint 7: 黑堡本地信息流 scraper =====
# GitHub Action 触发 scraper endpoint 时的鉴权 secret
# 生产环境用 `openssl rand -hex 32` 生成,GH repo secrets 和 Railway 两边值要一致
SCRAPER_SECRET=

# ===== LLM(用于 HTML 提取 + 中文摘要翻译) =====
# 默认走 DeepSeek(便宜 + 中文友好),也可换成其他 OpenAI-compatible provider
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=deepseek-chat
LLM_UTILITY_MODEL=deepseek-chat

# ===== Embedding(Phase 3 RAG 用,Phase 1 可暂不填) =====
LLM_EMBED_BASE_URL=https://api.openai.com/v1
LLM_EMBED_API_KEY=
LLM_EMBED_MODEL=text-embedding-3-small

# ===== Sprint 7 Phase 3B: Magic-link 邮箱登录 + OG 分享卡片 =====
# 站点公开 URL(Magic-link 邮件正文 + OG 图链接 + 微信群分享链接里用)
# 生产: https://your-domain;本地 dev 可空,代码自动 fallback http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Resend 邮件服务(magic-link 发送登录链接用)
# 注册 https://resend.com 拿免费 100 封/天的 API key
# 本地 dev 留空 → server 会把 magic-link URL 打到 console.log(调试用,够测)
# 生产留空 → /api/auth/magic-link/send 返 503(magic-link 不可用,
# 但识别码方案仍工作,不影响发布/管理流程)
RESEND_API_KEY=
# 发件人地址。Resend 提供 onboarding@resend.dev(免域名验证,默认值)
# 自有域名(blacksburg-secondhand.com 之类)需先在 Resend dashboard verify
EMAIL_FROM_ADDRESS=onboarding@resend.dev
