// 黑堡二手买卖数据模型
// Phase 1: SQLite（本地开发）
// Phase 4: 部署 Railway 时切换到 PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 商品 / 求购贴
model Item {
  id                  String   @id @default(cuid())
  type                String   // "sell" | "buy"
  title               String
  description         String
  price               Int?     // null = 面议；单位 USD（无小数）
  category            String   // "home" | "electronics" | "transport" | "books" | "other"
  customTag           String?  // 用户自填的标签（"乐器"、"宠物用品" 等）
  contactType         String   // "wechat" | "phone" | "email" | "other"
  contactValue        String
  customContactLabel  String?  // contactType=other 时（如 "Discord"）
  photoUrls           String   // JSON 序列化的 URL 数组（SQLite 不原生支持数组）
  editCodeHash        String   // bcrypt 哈希
  status              String   @default("active") // "active" | "deleted" | "hidden"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?  // 用于隐式限速
  utmSource           String?  // 用户首次访问时的 ?utm_source=xxx 或 ?from=xxx；用于渠道分析
  // contactRevealCount 字段已废弃 —— cartCount (CartEntry 表 visitor 去重计数) 完全取代
  // 之前的注释保留：联系方式被点击展示累计次数。Schema 字段已通过 migration 删除

  inquiries   Inquiry[]
  reports     Report[]     @relation("ItemReports")
  cartEntries CartEntry[]

  @@index([status, createdAt])
  @@index([category])
  @@index([type])
  @@index([utmSource])
}

// 询价 / 留言 —— 通用：二手 item 上的询价，或室友 listing 上的公开 Q&A
// itemId 和 listingId 二选一（exactly one），CHECK 在应用层保证
model Inquiry {
  id                  String   @id @default(cuid())
  itemId              String?  // 二手 inquiry（询价）
  listingId           String?  // 室友 listing 公开 Q&A
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  // 发布人回复（卖家 / 房东，用对应 editCode 鉴权后才能写）
  sellerReply         String?
  sellerRepliedAt     DateTime?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  item    Item?    @relation(fields: [itemId],    references: [id], onDelete: Cascade)
  listing Listing? @relation("ListingInquiries", fields: [listingId], references: [id], onDelete: Cascade)
  reports Report[] @relation("InquiryReports")

  @@index([itemId, createdAt])
  @@index([listingId, createdAt])
  @@index([contactValue])
}

// 二手购物清单 —— 买家把感兴趣的 item 加进本地购物清单时，server 也记一笔
// 用现有的 hb_vid cookie 跟 PageView 共用一个 visitor 概念
// 每个 (itemId, visitorId) 唯一约束 = 真实"独立持有人数"，去重，移除时 delete
model CartEntry {
  id        String   @id @default(cuid())
  itemId    String
  visitorId String   // 来自 hb_vid cookie
  addedAt   DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, visitorId])
  @@index([itemId])
}

// 页面访问统计 —— 用于 admin 后台自建轻量埋点
// 客户端 PageViewBeacon 在 pathname 变化时 fire-and-forget POST /api/pageview
// 服务端用 cookie 跟踪 visitorId（HttpOnly，1 年）；同一 visitorId 多次访问 = 同一 unique visitor
// 不做指纹，不存 IP（reporterIp 已经用于反垃圾，pageview 走 visitorId）
model PageView {
  id         String   @id @default(cuid())
  visitorId  String   // 来自 cookie 的匿名 id（crypto.randomUUID）
  path       String   // /, /item/[id], /roommates ...
  utmSource  String?  // 用户首次进站带的 ?utm_source=
  referer    String?  // document.referrer（如有）
  userAgent  String?  // truncated UA，用于粗粒度区分手机/桌面
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

// Cloudinary 待删队列：软删/换图时不立即 destroy，而是延迟 24h 给用户后悔时间
// 触发：每次 GET /api/items 时机会式扫一遍过期记录
model PendingCloudinaryDeletion {
  id           String   @id @default(cuid())
  publicId     String
  scheduledFor DateTime
  createdAt    DateTime @default(now())

  @@index([scheduledFor])
}

// ====== 室友&转租 平台 (Sprint 4) ======

// 室友 listing：自我介绍 + 房屋信息 + 7 个生活方式维度
model Listing {
  id                  String   @id @default(cuid())
  type                String   // "find_roommate" (A) | "co_rent" (B) | "sublet" (C) | "summer" (D)

  // 自我表达
  posterGender        String   @default("unspecified") // "F" | "M" | "nb" | "unspecified"
  ageRange            String?  // "<22" | "22-25" | "25-30" | "30+"
  lookingForGender    String   @default("any")         // "F-only" | "M-only" | "any"

  // 内容
  title               String
  description         String
  photoUrls           String   // JSON 字符串，同 Item

  // 房屋信息
  hasPlace            Boolean  @default(false)
  housingLayout       String?  // "1B1B" 等
  moveInStart         DateTime?
  moveInEnd           DateTime?
  moveInFuzzy         String?  // "immediate"|"within_month"|"spring_term"|"summer"|"fall_term"|"flexible" — A/B 的模糊入住时间
  budgetMin           Int?
  budgetMax           Int?
  areas               String   @default("[]") // JSON 字符串数组：["Foxridge", "Downtown"]
  currentResidents    Int?     // A: 现住几人（你将加入 N 人）
  furnished           Boolean? // C/D: 是否带家具

  // 7 个生活方式 chips
  sleepSchedule       String?  // "early" | "late" | "flexible"
  cleanliness         String?  // "neat" | "average" | "casual"
  social              String?  // "quiet" | "occasional" | "frequent"
  smoking             String?  // "no" | "ok" | "yes"
  drinking            String?  // "no" | "occasional" | "frequent"
  pets                String?  // "none" | "cat" | "dog" | "other"
  guests              String?  // "no" | "occasional" | "ok"

  // 联系方式（默认隐藏，approved 后双向可见）
  contactType         String
  contactValue        String
  customContactLabel  String?

  // 元信息
  editCodeHash        String
  status              String   @default("active")  // "active" | "matched" | "deleted" | "hidden" | "draft"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?
  utmSource           String?
  migratedFromItem    Boolean  @default(false)  // 旧 housing item 迁移标识

  applications        Application[]
  attachedTo          Application[] @relation("AttachedListing")
  reports             Report[]      @relation("ListingReports")
  inquiries           Inquiry[]     @relation("ListingInquiries")

  @@index([status, bumpedAt])
  @@index([type])
  @@index([contactValue])
}

// 申请-同意：B 申请联系 A 的 listing；A 决定后双方互相看到联系方式
model Application {
  id                  String   @id @default(cuid())
  listingId           String
  applicantGender     String   // "F" | "M" | "nb" | "unspecified"
  ageRange            String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  editCodeHash        String   // 申请人自己的识别码（用于查看/撤回自己的申请）
  attachedListingId   String?  // 申请人选择附上自己的 listing
  status              String   @default("pending")  // "pending" | "approved" | "rejected" | "cancelled"
  rejectReason        String?  // A 婉拒时可选填
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attachedListing     Listing? @relation("AttachedListing", fields: [attachedListingId], references: [id])
  reports             Report[] @relation("ApplicationReports")

  @@index([listingId, status])
  @@index([contactValue])
}

// 举报（扩展原 Report 加 listing / application）
model Report {
  id            String   @id @default(cuid())
  targetType    String   // "item" | "inquiry" | "listing" | "application"
  itemId        String?
  inquiryId     String?
  listingId     String?
  applicationId String?
  reason        String
  reporterIp    String?
  createdAt     DateTime @default(now())

  item        Item?        @relation("ItemReports",        fields: [itemId],        references: [id], onDelete: Cascade)
  inquiry     Inquiry?     @relation("InquiryReports",     fields: [inquiryId],     references: [id], onDelete: Cascade)
  listing     Listing?     @relation("ListingReports",     fields: [listingId],     references: [id], onDelete: Cascade)
  application Application? @relation("ApplicationReports", fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([inquiryId])
  @@index([listingId])
  @@index([applicationId])
}

// ====== 黑堡本地信息流 (Sprint 7) ======

// 本地事件 / 新闻 / 讨论 — 抓取下来统一存这张表
model Event {
  id              String    @id @default(cuid())
  source          String    // 'nextthreedays' | 'blacksburg_gov' | ...
  sourceUrl       String    // 原始 URL
  sourceId        String?   // 源站自带的 id(用于 dedup,可空)

  title           String    // 中文 + 英文专有名词混排
  titleOriginal   String?   // 英文原始标题(给展示用,可空)
  description     String?   // 中文摘要 ≤ 200 字

  startAt         DateTime?
  endAt           DateTime?
  location        String?

  category        String?   // 'events' | 'sports' | 'news' | 'discussion'
  imageUrl        String?
  qualityScore    Float     @default(0.7)  // LLM 估的 0.0-1.0,< 0.5 不展示

  scrapedAt       DateTime  @default(now())
  publishedAt     DateTime? // 源站标的发布时间

  // Phase 2A 热度跟踪 — 每次卡片被点击 +1(visitor 防刷 5 分钟去重在 API 层做)
  clickCount      Int       @default(0)

  // === Phase 3A 用户发布字段(scraped events 这些 null) ===
  // source = 'user' 时启用
  posterCodeHash      String?  // bcrypt 识别码,跟 Item/Listing 同款
  posterVisitorId     String?  // server-only,用于路由"发送联系方式给 poster"
  posterNickname      String?
  posterContactType   String?  // wechat | phone | discord | email | other
  posterContact       String?
  posterContactLabel  String?  // contactType=other 时用户自填(如 'Line')
  posterContactPublic Boolean? @default(false)  // 是否公开显示联系方式
  customCategory      String?  // category='other' 时用户自填的类目名
  photoUrls           String?  // JSON 序列化 URL 数组,跟 Item.photoUrls 同款

  // Phase 3 chat 用,Phase 1 留空。pgvector 类型在 SQLite 不支持,先省略字段
  // Postgres 上来时通过 raw SQL migrate 加 embedding 列

  status          String    @default("active")  // active | fulfilled | canceled | expired | hidden | deleted

  // Phase 3B: 想找几人 hint(可空 = 不限)
  maxAttendees    Int?

  @@unique([source, sourceUrl])
  @@index([startAt])
  @@index([source])
  @@index([status, startAt])
  @@index([category])
  @@index([clickCount])
  @@index([posterVisitorId])  // Phase 3A 用户在"我的"看自己发布的活动
}

// Phase 2A 防刷:同 visitor 5 分钟内对同一 event 只算一次 click
model EventClickThrottle {
  id          String   @id @default(cuid())
  eventId     String
  visitorId   String
  createdAt   DateTime @default(now())

  @@unique([eventId, visitorId])
  @@index([createdAt])
}

// Phase 2C 评论:每个 event 下的讨论
// 用 visitorId(hb_vid cookie)做身份 — 无登录系统,但 cookie 1 年内稳定
model EventComment {
  id          String   @id @default(cuid())
  eventId     String
  visitorId   String   // 跟 hb_vid 对应
  nickname    String   // 必填,展示用
  content     String   // ≤ 300 字
  status      String   @default("active")  // active | hidden | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId, status, createdAt])
  @@index([visitorId])
}

// Phase 2C 联系方式发送(Sean 设计:单向无 accept/decline)
// 配对逻辑:同一 event 内存在 (A→B) 和 (B→A) 两条 = 双方互见联系方式
// A 不知道 B 是否"拒绝",只感觉"可能没看到" — 低社交压力
model EventContactSend {
  id              String   @id @default(cuid())
  eventId         String
  fromVisitorId   String   // 发起者
  fromNickname    String   // 冗余存方便展示(发送时拍快照)
  fromContactType String   // 'wechat' | 'phone' | 'discord' | 'email' | 'other'
  fromContact     String   // 联系方式本体(如微信号 / 手机号)
  fromContactLabel String? // contactType=other 时用户自填的 label(如 'Line')
  toVisitorId     String   // 目标(目标评论作者)
  toCommentId     String?  // 关联到具体评论(deep link 用,可空)
  status          String   @default("active")  // active | archived | canceled(响应者撤回)
  readAt          DateTime?  // 接收方第一次"我的"展开时记录
  createdAt       DateTime @default(now())

  // Phase 3B: 响应活动 / 求助场景独立字段
  // nickname: 响应者填的昵称(独立于 fromNickname,后者来自评论上下文)
  // note: "我有车" / "我能搬重物" 等一行话备注
  nickname        String?
  note            String?

  @@unique([eventId, fromVisitorId, toVisitorId])  // 同 event 同方向只能发一次
  @@index([toVisitorId, status, createdAt])
  @@index([fromVisitorId, status])
}

// 抓取运行记录 — 每个源每次跑都记一笔,失败排错用
model ScrapeRun {
  id          String    @id @default(cuid())
  source      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    // running | success | failed
  itemsFound  Int       @default(0)
  itemsNew    Int       @default(0)
  errorMsg    String?

  @@index([source, startedAt])
}

// 识别码找回回路 (Sprint 6 UX-5):用户丢识别码后,提交申请,Sean admin 人工处理
// 心理学依据:H9 Error Recovery + Negativity Bias —— 失败体验的兜底路径
model RecoveryRequest {
  id                 String   @id @default(cuid())
  targetType         String   // "item" | "listing"
  targetId           String?  // 原帖 id(用户可能记不住,可空)
  targetContactValue String   // 申请人记得的联系方式,Sean 用来匹配 + 验证
  applicantWechat    String   // 申请人微信号(Sean 加好友用)
  applicantNote      String?  // 申请人描述帖子细节,用于身份验证
  ipAddress          String?
  status             String   @default("pending") // pending | contacted | resolved | rejected | abuse
  adminNotes         String?
  resolvedEditCode   String?  // resolved 时记录新生成的 editCode 明文,Sean 微信发
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
  @@index([targetId])
}

// ====== Sprint 7 Phase 3B: Magic-link 邮箱登录 ======
// 不强制登录,只作为"自动预填"通道 — 识别码方案仍保留

// 单次使用 token,15 分钟过期。用户邮箱填 → 发链接 → 点链接 → 写 UserSession
model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([token])
}

// 长期 session(30 天),cookie 里只存 sessionToken
// 表里冗余存 contactValue/contactType/nickname 让发布表单一查就能预填
model UserSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  email        String
  contactValue String?
  contactType  String?
  nickname     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([sessionToken])
  @@index([email])
}
