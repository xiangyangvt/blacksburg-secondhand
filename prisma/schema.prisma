// 黑堡二手买卖数据模型
// Phase 1: SQLite（本地开发）
// Phase 4: 部署 Railway 时切换到 PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 商品 / 求购贴
model Item {
  id                  String   @id @default(cuid())
  type                String   // "sell" | "buy"
  title               String
  description         String
  price               Int?     // null = 面议；单位 USD（无小数）
  category            String   // "home" | "electronics" | "transport" | "books" | "other"
  customTag           String?  // 用户自填的标签（"乐器"、"宠物用品" 等）
  contactType         String   // "wechat" | "phone" | "email" | "other"
  contactValue        String
  customContactLabel  String?  // contactType=other 时（如 "Discord"）
  photoUrls           String   // JSON 序列化的 URL 数组（SQLite 不原生支持数组）
  editCodeHash        String   // bcrypt 哈希
  status              String   @default("active") // "active" | "deleted" | "hidden"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?  // 用于隐式限速
  utmSource           String?  // 用户首次访问时的 ?utm_source=xxx 或 ?from=xxx；用于渠道分析
  contactRevealCount  Int      @default(0)  // 联系方式被点击展示的累计次数（同 IP 24h 内去重）

  inquiries Inquiry[]
  reports   Report[]  @relation("ItemReports")

  @@index([status, createdAt])
  @@index([category])
  @@index([type])
  @@index([utmSource])
}

// 询价 / 留言
model Inquiry {
  id                  String   @id @default(cuid())
  itemId              String
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  // 卖家回复（用商品 editCode 鉴权后才能写）
  sellerReply         String?
  sellerRepliedAt     DateTime?
  status              String   @default("active") // "active" | "hidden"（3 个不同 IP 举报后自动 hidden，仅 admin 可见）
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  item    Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reports Report[] @relation("InquiryReports")

  @@index([itemId, createdAt])
  @@index([contactValue])
}

// 页面访问统计 —— 用于 admin 后台自建轻量埋点
// 客户端 PageViewBeacon 在 pathname 变化时 fire-and-forget POST /api/pageview
// 服务端用 cookie 跟踪 visitorId（HttpOnly，1 年）；同一 visitorId 多次访问 = 同一 unique visitor
// 不做指纹，不存 IP（reporterIp 已经用于反垃圾，pageview 走 visitorId）
model PageView {
  id         String   @id @default(cuid())
  visitorId  String   // 来自 cookie 的匿名 id（crypto.randomUUID）
  path       String   // /, /item/[id], /roommates ...
  utmSource  String?  // 用户首次进站带的 ?utm_source=
  referer    String?  // document.referrer（如有）
  userAgent  String?  // truncated UA，用于粗粒度区分手机/桌面
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

// Cloudinary 待删队列：软删/换图时不立即 destroy，而是延迟 24h 给用户后悔时间
// 触发：每次 GET /api/items 时机会式扫一遍过期记录
model PendingCloudinaryDeletion {
  id           String   @id @default(cuid())
  publicId     String
  scheduledFor DateTime
  createdAt    DateTime @default(now())

  @@index([scheduledFor])
}

// ====== 室友&转租 平台 (Sprint 4) ======

// 室友 listing：自我介绍 + 房屋信息 + 7 个生活方式维度
model Listing {
  id                  String   @id @default(cuid())
  type                String   // "find_roommate" (A) | "co_rent" (B) | "sublet" (C) | "summer" (D)

  // 自我表达
  posterGender        String   @default("unspecified") // "F" | "M" | "nb" | "unspecified"
  ageRange            String?  // "<22" | "22-25" | "25-30" | "30+"
  lookingForGender    String   @default("any")         // "F-only" | "M-only" | "any"

  // 内容
  title               String
  description         String
  photoUrls           String   // JSON 字符串，同 Item

  // 房屋信息
  hasPlace            Boolean  @default(false)
  housingLayout       String?  // "1B1B" 等
  moveInStart         DateTime?
  moveInEnd           DateTime?
  moveInFuzzy         String?  // "immediate"|"within_month"|"spring_term"|"summer"|"fall_term"|"flexible" — A/B 的模糊入住时间
  budgetMin           Int?
  budgetMax           Int?
  areas               String   @default("[]") // JSON 字符串数组：["Foxridge", "Downtown"]
  currentResidents    Int?     // A: 现住几人（你将加入 N 人）
  furnished           Boolean? // C/D: 是否带家具

  // 7 个生活方式 chips
  sleepSchedule       String?  // "early" | "late" | "flexible"
  cleanliness         String?  // "neat" | "average" | "casual"
  social              String?  // "quiet" | "occasional" | "frequent"
  smoking             String?  // "no" | "ok" | "yes"
  drinking            String?  // "no" | "occasional" | "frequent"
  pets                String?  // "none" | "cat" | "dog" | "other"
  guests              String?  // "no" | "occasional" | "ok"

  // 联系方式（默认隐藏，approved 后双向可见）
  contactType         String
  contactValue        String
  customContactLabel  String?

  // 元信息
  editCodeHash        String
  status              String   @default("active")  // "active" | "matched" | "deleted" | "hidden" | "draft"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?
  utmSource           String?
  migratedFromItem    Boolean  @default(false)  // 旧 housing item 迁移标识

  applications        Application[]
  attachedTo          Application[] @relation("AttachedListing")
  reports             Report[]      @relation("ListingReports")

  @@index([status, bumpedAt])
  @@index([type])
  @@index([contactValue])
}

// 申请-同意：B 申请联系 A 的 listing；A 决定后双方互相看到联系方式
model Application {
  id                  String   @id @default(cuid())
  listingId           String
  applicantGender     String   // "F" | "M" | "nb" | "unspecified"
  ageRange            String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  editCodeHash        String   // 申请人自己的识别码（用于查看/撤回自己的申请）
  attachedListingId   String?  // 申请人选择附上自己的 listing
  status              String   @default("pending")  // "pending" | "approved" | "rejected" | "cancelled"
  rejectReason        String?  // A 婉拒时可选填
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attachedListing     Listing? @relation("AttachedListing", fields: [attachedListingId], references: [id])
  reports             Report[] @relation("ApplicationReports")

  @@index([listingId, status])
  @@index([contactValue])
}

// 举报（扩展原 Report 加 listing / application）
model Report {
  id            String   @id @default(cuid())
  targetType    String   // "item" | "inquiry" | "listing" | "application"
  itemId        String?
  inquiryId     String?
  listingId     String?
  applicationId String?
  reason        String
  reporterIp    String?
  createdAt     DateTime @default(now())

  item        Item?        @relation("ItemReports",        fields: [itemId],        references: [id], onDelete: Cascade)
  inquiry     Inquiry?     @relation("InquiryReports",     fields: [inquiryId],     references: [id], onDelete: Cascade)
  listing     Listing?     @relation("ListingReports",     fields: [listingId],     references: [id], onDelete: Cascade)
  application Application? @relation("ApplicationReports", fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([inquiryId])
  @@index([listingId])
  @@index([applicationId])
}
