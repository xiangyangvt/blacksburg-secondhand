// 生产环境用 schema（PostgreSQL）
// Railway 部署时，build:prod / start:prod 通过 `--schema=prisma/schema.production.prisma` 直接引用。
// 本地开发请用 prisma/schema.prisma（SQLite，零摩擦）。两个 schema 互不污染。

generator client {
  provider      = "prisma-client-js"
  // Railway / 大多数 Linux 容器需要 musl 引擎，否则运行时报 "Could not load engine"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id                  String   @id @default(cuid())
  type                String
  title               String
  description         String
  price               Int?
  category            String
  customTag           String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  photoUrls           String   // JSON 序列化（保留兼容 SQLite 时期写入的格式）
  editCodeHash        String
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?

  inquiries Inquiry[]
  reports   Report[]  @relation("ItemReports")

  @@index([status, createdAt])
  @@index([category])
  @@index([type])
}

model Inquiry {
  id                  String   @id @default(cuid())
  itemId              String
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  sellerReply         String?
  sellerRepliedAt     DateTime?
  status              String   @default("active") // "active" | "hidden"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?

  item    Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reports Report[] @relation("InquiryReports")

  @@index([itemId, createdAt])
  @@index([contactValue])
}

model Report {
  id          String   @id @default(cuid())
  targetType  String
  itemId      String?
  inquiryId   String?
  reason      String
  reporterIp  String?
  createdAt   DateTime @default(now())

  item    Item?    @relation("ItemReports",    fields: [itemId],    references: [id], onDelete: Cascade)
  inquiry Inquiry? @relation("InquiryReports", fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([inquiryId])
}
