// 生产环境用 schema（PostgreSQL）
// Railway 部署时，build:prod / start:prod 通过 `--schema=prisma/schema.production.prisma` 直接引用。
// 本地开发请用 prisma/schema.prisma（SQLite，零摩擦）。两个 schema 互不污染。

generator client {
  provider      = "prisma-client-js"
  // Railway / 大多数 Linux 容器需要 musl 引擎，否则运行时报 "Could not load engine"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id                  String   @id @default(cuid())
  type                String
  title               String
  description         String
  price               Int?
  category            String
  customTag           String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  photoUrls           String   // JSON 序列化（保留兼容 SQLite 时期写入的格式）
  editCodeHash        String
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?
  utmSource           String?
  // contactRevealCount 字段已废弃，由 cartCount (CartEntry 表) 取代

  inquiries   Inquiry[]
  reports     Report[]     @relation("ItemReports")
  cartEntries CartEntry[]

  @@index([status, createdAt])
  @@index([category])
  @@index([type])
  @@index([utmSource])
}

model Inquiry {
  id                  String   @id @default(cuid())
  itemId              String?
  listingId           String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  sellerReply         String?
  sellerRepliedAt     DateTime?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  item    Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  listing Listing? @relation("ListingInquiries", fields: [listingId], references: [id], onDelete: Cascade)
  reports Report[] @relation("InquiryReports")

  @@index([itemId, createdAt])
  @@index([listingId, createdAt])
  @@index([contactValue])
}

model CartEntry {
  id        String   @id @default(cuid())
  itemId    String
  visitorId String
  addedAt   DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, visitorId])
  @@index([itemId])
}

model PageView {
  id         String   @id @default(cuid())
  visitorId  String
  path       String
  utmSource  String?
  referer    String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

model PendingCloudinaryDeletion {
  id           String   @id @default(cuid())
  publicId     String
  scheduledFor DateTime
  createdAt    DateTime @default(now())

  @@index([scheduledFor])
}

// ====== 室友&转租 平台 (Sprint 4) ======

model Listing {
  id                  String   @id @default(cuid())
  type                String

  posterGender        String   @default("unspecified")
  ageRange            String?
  lookingForGender    String   @default("any")

  title               String
  description         String
  photoUrls           String

  hasPlace            Boolean  @default(false)
  housingLayout       String?
  moveInStart         DateTime?
  moveInEnd           DateTime?
  moveInFuzzy         String?
  budgetMin           Int?
  budgetMax           Int?
  areas               String   @default("[]")
  currentResidents    Int?
  furnished           Boolean?

  sleepSchedule       String?
  cleanliness         String?
  social              String?
  smoking             String?
  drinking            String?
  pets                String?
  guests              String?

  contactType         String
  contactValue        String
  customContactLabel  String?

  editCodeHash        String
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bumpedAt            DateTime @default(now())
  ipAddress           String?
  utmSource           String?
  migratedFromItem    Boolean  @default(false)

  applications        Application[]
  attachedTo          Application[] @relation("AttachedListing")
  reports             Report[]      @relation("ListingReports")
  inquiries           Inquiry[]     @relation("ListingInquiries")

  @@index([status, bumpedAt])
  @@index([type])
  @@index([contactValue])
}

model Application {
  id                  String   @id @default(cuid())
  listingId           String
  applicantGender     String
  ageRange            String?
  contactType         String
  contactValue        String
  customContactLabel  String?
  message             String
  editCodeHash        String
  attachedListingId   String?
  status              String   @default("pending")
  rejectReason        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipAddress           String?
  utmSource           String?

  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attachedListing     Listing? @relation("AttachedListing", fields: [attachedListingId], references: [id])
  reports             Report[] @relation("ApplicationReports")

  @@index([listingId, status])
  @@index([contactValue])
}

model Report {
  id            String   @id @default(cuid())
  targetType    String
  itemId        String?
  inquiryId     String?
  listingId     String?
  applicationId String?
  reason        String
  reporterIp    String?
  createdAt     DateTime @default(now())

  item        Item?        @relation("ItemReports",        fields: [itemId],        references: [id], onDelete: Cascade)
  inquiry     Inquiry?     @relation("InquiryReports",     fields: [inquiryId],     references: [id], onDelete: Cascade)
  listing     Listing?     @relation("ListingReports",     fields: [listingId],     references: [id], onDelete: Cascade)
  application Application? @relation("ApplicationReports", fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([inquiryId])
  @@index([listingId])
  @@index([applicationId])
}
